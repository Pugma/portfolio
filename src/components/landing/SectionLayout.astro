---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<section>
  {title === "" ? null : <h2>{title}</h2>}
  <slot />
</section>

<style>
  section {
    margin: 16px;
    padding: 16px 24px;

    border: #0969da 1px solid;
    border-radius: 16px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
  }
</style>
