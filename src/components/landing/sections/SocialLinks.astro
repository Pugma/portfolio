---
import { socialLinks } from "../../../data/social-links";
import AccountButton from "../../AccountButton.astro";
---

<div class="accounts">
  {
    socialLinks.map((link) => (
      <AccountButton
        icon={link.icon}
        accountId={link.accountId}
        color={link.color}
        url={link.url}
      />
    ))
  }
</div>

<style>
  .accounts {
    display: grid;
    flex-grow: 1;
    grid-template-columns: repeat(auto-fit, minmax(10rem, 1fr));
    gap: 8px;
  }
</style>
