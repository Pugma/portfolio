---
import SectionLayout from "../SectionLayout.astro";
import Pugma from "../../../assets/Pugma.png";
import { Image } from "astro:assets";
import SocialLinks from "./SocialLinks.astro";
---

<SectionLayout title="">
  <div class="profile">
    <div class="profile-left">
      <Image
        src={Pugma}
        alt="ぷぐまのプロフィール画像"
        width={150}
        height={150}
        style="border-radius: 50%; margin-bottom: 16px;"
      />
      <h2>ぷぐま</h2>
    </div>
    <SocialLinks />
  </div>
</SectionLayout>

<style>
  .profile {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 32px;
  }

  .profile-left {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }
</style>
