---



import { type WorkKey, works } from "../../data/works";
import TileItem from "./TileItem.astro";

const workKeys = Object.keys(works) as WorkKey[];
---

<div
  class="grid grid-cols-[repeat(auto-fit,minmax(20rem,1fr))] justify-items-center gap-x-4 gap-y-3"
>
  {
    workKeys.map((key) => {
      const work = works[key];
      return (
        <TileItem
          workKey={key}
          title={work.title}
          description={work.description}
          thumbnail={work.thumbnail}
          tags={work.tags}
          roles={work.roles}
          links={work.links}
          image={work.image}
        />
      );
    })
  }
</div>
