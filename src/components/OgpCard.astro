---
import ogs from "open-graph-scraper";

interface Props {
  url: string;
  publishedAt: string;
}

const { url, publishedAt } = Astro.props;

const { result } = await ogs({ url });
const title = result.ogTitle ?? url;
const description = result.ogDescription ?? "";
const image = result.ogImage?.[0]?.url;
---

<a href={url} target="_blank" rel="noopener noreferrer" class="ogp-card">
  {image && <img src={image} alt="" class="ogp-image" />}
  <div class="flex flex-col grow gap-2 min-w-0">
    <h3 class="ogp-title">{title}</h3>
    {description && <p class="ogp-description">{description}</p>}
    <span class="ogp-source">{publishedAt}</span>
  </div>
</a>

<style>
  .ogp-card {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 16px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    text-decoration: none;
    color: inherit;
    overflow: hidden;
  }

  .ogp-card:hover {
    background-color: var(--color-button-hover);
  }

  .ogp-image {
    width: 120px;
    height: 80px;
    object-fit: cover;
    border-radius: var(--radius-md);
    flex-shrink: 0;
  }

  .ogp-title {
    font-size: 1rem;
    margin: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .ogp-description {
    font-size: 0.85rem;
    color: var(--color-text);
    opacity: 0.7;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .ogp-source {
    font-size: 0.75rem;
    color: var(--color-text);
    opacity: 0.5;
  }
</style>
