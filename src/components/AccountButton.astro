---
import { Icon } from "astro-icon/components";
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  icon: string | ImageMetadata;
  accountId: string;
  color?: string;
  url: string;
}

const { icon, accountId, color = "#000000", url } = Astro.props;

// WCAG relative luminance from hex color
function luminance(hex: string): number {
  const r = parseInt(hex.slice(1, 3), 16) / 255;
  const g = parseInt(hex.slice(3, 5), 16) / 255;
  const b = parseInt(hex.slice(5, 7), 16) / 255;
  const toLinear = (c: number) =>
    c <= 0.03928 ? c / 12.92 : ((c + 0.055) / 1.055) ** 2.4;
  return 0.2126 * toLinear(r) + 0.7152 * toLinear(g) + 0.0722 * toLinear(b);
}

const fg = luminance(color) > 0.36 ? "#000000" : "#ffffff";
---

<a
  href={url}
  target="_blank"
  rel="noopener"
  class="account-button"
  style={`background-color: ${color}; color: ${fg};`}
>
  {
    typeof icon === "string" ? (
      <Icon
        name={icon}
        size={24}
        is:inline={true}
        color={fg}
        class="account-icon"
      />
    ) : (
      <Image src={icon} alt={`${accountId} icon`} class="account-icon" />
    )
  }

  <span class="account-id">{accountId}</span>
</a>

<style>
  .account-button {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 16px;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    transition: opacity 0.2s ease;
  }

  .account-button:hover {
    opacity: 0.85;
  }

  .account-icon {
    width: auto;
    max-width: 24px;
    height: 24px;
    object-fit: contain;
  }

  .account-id {
    font-size: 14px;
  }
</style>
